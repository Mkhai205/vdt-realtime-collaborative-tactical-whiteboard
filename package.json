{
  "name": "realtime-collaborative-tactical-whiteboard",
  "version": "0.1.0",
  "private": true,
  "author": "MKhai205",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@rctw/web",
    "dev:api": "turbo run dev --filter=@rctw/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@rctw/web",
    "build:api": "turbo run build --filter=@rctw/api",
    "build:sc": "turbo run build --filter=@rctw/shared-contracts",
    "build:db": "turbo run build --filter=@rctw/database",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.2"
