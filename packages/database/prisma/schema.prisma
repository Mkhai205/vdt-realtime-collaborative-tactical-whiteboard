generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum IdentityType {
  GUEST
  GOOGLE
}

enum BoardRole {
  OWNER
  EDITOR
  VIEWER
}

enum ObjectType {
  RECTANGLE
  CIRCLE
  LINE
  TEXT
}

enum OperationType {
  OBJECT_CREATE
  OBJECT_UPDATE
  OBJECT_DELETE
  OBJECT_RESTORE
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String?      @unique
  name         String       @db.VarChar(120)
  avatarUrl    String?      @db.Text
  avatarColor  String       @default("#3B82F6") @db.VarChar(20)
  identityType IdentityType @default(GUEST)
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @db.Timestamptz(6)

  createdBoards  Board[]               @relation("BoardCreator")
  memberships    BoardMember[]
  operations     WhiteboardOperation[]
  objectsCreated WhiteboardObject[]    @relation("ObjectCreator")
  objectsUpdated WhiteboardObject[]    @relation("ObjectUpdater")
}

model Board {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(160)
  description     String?   @db.Text
  createdById     String    @db.Uuid
  currentRevision BigInt    @default(0)
  isPublic        Boolean   @default(true)
  defaultJoinRole BoardRole @default(EDITOR)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime? @db.Timestamptz(6)

  createdBy  User                  @relation("BoardCreator", fields: [createdById], references: [id])
  members    BoardMember[]
  objects    WhiteboardObject[]
  operations WhiteboardOperation[]
  snapshots  BoardSnapshot[]

  @@index([createdById])
  @@index([isPublic])
  @@index([deletedAt])
}

model BoardMember {
  id        String    @id @default(uuid()) @db.Uuid
  boardId   String    @db.Uuid
  userId    String    @db.Uuid
  role      BoardRole
  joinedAt  DateTime  @default(now()) @db.Timestamptz(6)
  removedAt DateTime? @db.Timestamptz(6)

  board Board @relation(fields: [boardId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@index([boardId, role])
  @@index([userId])
}

model WhiteboardObject {
  id          String     @id @default(uuid()) @db.Uuid
  boardId     String     @db.Uuid
  type        ObjectType
  x           Float
  y           Float
  width       Float?
  height      Float?
  points      Json?
  text        String?    @db.Text
  rotation    Float      @default(0)
  style       Json
  zIndex      Int        @default(0)
  version     Int        @default(1)
  createdById String     @db.Uuid
  updatedById String?    @db.Uuid
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?  @db.Timestamptz(6)

  board      Board                 @relation(fields: [boardId], references: [id])
  createdBy  User                  @relation("ObjectCreator", fields: [createdById], references: [id])
  updatedBy  User?                 @relation("ObjectUpdater", fields: [updatedById], references: [id])
  operations WhiteboardOperation[]

  @@index([boardId])
  @@index([boardId, deletedAt])
  @@index([boardId, zIndex])
  @@index([createdById])
}

model WhiteboardOperation {
  id                String        @id @default(uuid()) @db.Uuid
  clientOpId        String        @db.VarChar(120)
  boardId           String        @db.Uuid
  actorId           String        @db.Uuid
  objectId          String?       @db.Uuid
  revision          BigInt
  type              OperationType
  baseObjectVersion Int?
  payload           Json
  inversePayload    Json?
  createdAt         DateTime      @default(now()) @db.Timestamptz(6)

  board  Board             @relation(fields: [boardId], references: [id])
  actor  User              @relation(fields: [actorId], references: [id])
  object WhiteboardObject? @relation(fields: [objectId], references: [id])

  @@unique([boardId, clientOpId])
  @@unique([boardId, revision])
  @@index([boardId, revision])
  @@index([objectId])
  @@index([actorId])
  @@index([createdAt])
}

model BoardSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  boardId   String   @db.Uuid
  revision  BigInt
  data      Json
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  board Board @relation(fields: [boardId], references: [id])

  @@unique([boardId, revision])
}
