generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum BoardRole {
  OWNER
  EDITOR
  VIEWER
}

enum ObjectType {
  RECTANGLE
  CIRCLE
  LINE
  TEXT
}

enum OperationType {
  OBJECT_CREATE
  OBJECT_UPDATE
  OBJECT_DELETE
  OBJECT_RESTORE
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String?  @unique
  googleId    String?  @unique
  name        String   @db.VarChar(120)
  avatarUrl   String?  @db.Text
  avatarColor String   @default("#3B82F6") @db.VarChar(20)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  createdBoards  Board[]          @relation("BoardCreator")
  memberships    BoardMember[]
  operations     BoardOperation[]
  objectsCreated BoardObject[]    @relation("ObjectCreator")
  objectsUpdated BoardObject[]    @relation("ObjectUpdater")
  refreshTokens  RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  expiresAt DateTime  @db.Timestamptz(6)
  revokedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Board {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(160)
  description     String?   @db.Text
  createdById     String    @db.Uuid
  currentRevision Int       @default(0)
  isPublic        Boolean   @default(true)
  defaultJoinRole BoardRole @default(EDITOR)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  createdBy  User             @relation("BoardCreator", fields: [createdById], references: [id])
  members    BoardMember[]
  objects    BoardObject[]
  operations BoardOperation[]
  snapshots  BoardSnapshot[]

  @@index([createdById])
  @@index([isPublic])
}

model BoardMember {
  id        String    @id @default(uuid()) @db.Uuid
  boardId   String    @db.Uuid
  userId    String    @db.Uuid
  role      BoardRole
  joinedAt  DateTime  @default(now()) @db.Timestamptz(6)
  removedAt DateTime? @db.Timestamptz(6)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@index([boardId, role])
  @@index([userId])
}

model BoardObject {
  id          String     @id @default(uuid()) @db.Uuid
  boardId     String     @db.Uuid
  type        ObjectType
  x           Float
  y           Float
  width       Float?
  height      Float?
  points      Json?
  text        String?    @db.Text
  rotation    Float      @default(0)
  style       Json
  zIndex      Int        @default(0)
  version     Int        @default(1)
  createdById String     @db.Uuid
  updatedById String?    @db.Uuid
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?  @db.Timestamptz(6)

  board      Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy  User             @relation("ObjectCreator", fields: [createdById], references: [id])
  updatedBy  User?            @relation("ObjectUpdater", fields: [updatedById], references: [id])
  operations BoardOperation[]

  @@index([boardId])
  @@index([boardId, deletedAt])
  @@index([boardId, zIndex])
  @@index([createdById])
}

model BoardOperation {
  id                String        @id @default(uuid()) @db.Uuid
  clientOpId        String        @db.VarChar(120)
  boardId           String        @db.Uuid
  actorId           String        @db.Uuid
  objectId          String?       @db.Uuid
  revision          Int
  type              OperationType
  baseObjectVersion Int?
  payload           Json
  inversePayload    Json?
  createdAt         DateTime      @default(now()) @db.Timestamptz(6)

  board  Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor  User         @relation(fields: [actorId], references: [id])
  object BoardObject? @relation(fields: [objectId], references: [id])

  @@unique([boardId, clientOpId])
  @@unique([boardId, revision])
  @@index([boardId, revision])
  @@index([objectId])
  @@index([actorId])
  @@index([createdAt])
}

model BoardSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  boardId   String   @db.Uuid
  revision  Int
  data      Json
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, revision])
}
